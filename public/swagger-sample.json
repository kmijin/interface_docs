    "/api/v1/parameter/modify": {
      "post": {
        "tags": [
          "파라미터"
        ],
        "summary": "Parameter 수정",
        "description": "Parameter 정보를 수정합니다.",
        "operationId": "modify",
        "requestBody": {
          "description": "수정할 파라메터 정보",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParameterModifyRequest"
              },
              "examples": {
                "혼잡도 기준 변경": {
                  "summary": "혼잡도 기준(%) 변경",
                  "description": "혼잡도 기준 변경",
                  "value": {
                    "parameterId": "CONGESTION",
                    "parameterKey": "BASIC",
                    "parameterValue": "80"
                  }
                },
                "P1층 분산 거리 변경": {
                  "summary": "P1층 분산 거리(m) 변경",
                  "description": "P1층 분산 거리 변경",
                  "value": {
                    "parameterId": "FLOOR_SPLIT_DISTANCE",
                    "parameterKey": "P1",
                    "parameterValue": "30"
                  }
                },
                "P2층 분산 거리 변경": {
                  "summary": "P2층 분산 거리(m) 변경",
                  "description": "P2층 분산 거리 변경",
                  "value": {
                    "parameterId": "FLOOR_SPLIT_DISTANCE",
                    "parameterKey": "P2",
                    "parameterValue": "30"
                  }
                },
                "층 변경 패널티 변경": {
                  "summary": "층 변경 패널티 거리(m) 변경",
                  "description": "층 변경 패널티 변경",
                  "value": {
                    "parameterId": "FLOOR_CHANGE_PENALTY",
                    "parameterKey": "BASIC",
                    "parameterValue": "30"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemResponseParameterModifyResponse"
                }
              }
            }
          },
          "300": {
            "description": "No Data\n- 조회한 데이터가 없음.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "ER_CT_05",
                  "message": "데이터가 존재하지 않습니다."
                }
              }
            }
          },
          "301": {
            "description": "Data Processing Error\n- 로직 처리중 Exception 발생. 개발자에게 문의 필요.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "ER_SV_02",
                  "message": "데이터를 처리하는데 실패하였습니다."
                }
              }
            }
          },
          "400": {
            "description": "Bad Request\n- 요청한 정보가 올바른지 확인한다.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "ER_CT_01",
                  "message": "적합하지 않은 인자가 전달되었습니다."
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error\n- 서버 에러 로그 확인을 요청한다.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "ER_SV_01",
                  "message": "요청한 서비스에 문제가 발생했습니다. 잠시 후에 다시 시도해 주세요."
                }
              }
            }
          }
        }
      }
