  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "공통 오류 응답 구조체",
        "properties": {
          "status": {
            "type": "string",
            "description": "상태 코드",
            "example": "ER_SV_01"
          },
          "message": {
            "type": "string",
            "description": "메시지",
            "example": "요청한 서비스에 문제가 발생했습니다. 잠시 후에 다시 시도해 주세요."
          },
          "detailMessage": {
            "type": "string",
            "description": "상세 메시지",
            "example": "관리자에게 문의하세요!"
          }
        }
      },
      "ParameterModifyRequest": {
        "type": "object",
        "description": "Parameter Modify Request Record",
        "properties": {
          "parameterId": {
            "type": "string",
            "description": "파라메터 아이디",
            "example": "FLOOR_SPLIT_DISTANCE",
            "maxLength": 50,
            "minLength": 0
          },
          "parameterKey": {
            "type": "string",
            "description": "파라메터 키",
            "example": "P1",
            "maxLength": 20,
            "minLength": 0
          },
          "parameterValue": {
            "type": "string",
            "description": "파라메터 값",
            "example": 50,
            "maxLength": 50,
            "minLength": 0
          }
        },
        "required": [
          "parameterId",
          "parameterKey"
        ]
      },
      "ItemResponseParameterModifyResponse": {
        "type": "object",
        "description": "공통 응답 구조체",
        "properties": {
          "status": {
            "type": "string",
            "description": "상태 코드",
            "example": "OK"
          },
          "message": {
            "type": "string",
            "description": "메시지",
            "example": "데이터를 조회하는데 성공하였습니다."
          },
          "item": {
            "$ref": "#/components/schemas/ParameterModifyResponse",
            "description": "응답 객체"
          }
        }
      },
      "ParameterModifyResponse": {
        "type": "object",
        "description": "Parameter Modify Response Record",
        "properties": {
          "parameterId": {
            "type": "string",
            "description": "파라메터 아이디",
            "example": "FLOOR_SPLIT_DISTANCE"
          },
          "parameterKey": {
            "type": "string",
            "description": "파라메터 키",
            "example": "P1"
          },
          "parameterName": {
            "type": "string",
            "description": "파라메터 이름",
            "example": "P1 층 분산 거리"
          },
          "parameterValue": {
            "type": "string",
            "description": "파라메터 값",
            "example": 50
          },
          "parameterExplanation": {
            "type": "string",
            "description": "파라메터 설명",
            "example": "층 분산 시 사용되는 POI 와의 거리"
          },
          "createDate": {
            "type": "string",
            "format": "date-time",
            "description": "생성 일시",
            "example": "2025-04-29 00:00:00"
          },
          "modifyDate": {
            "type": "string",
            "format": "date-time",
            "description": "수정 일시",
            "example": "2025-04-29 00:00:00"
          }
        }
      },
      "ItemResponseOptimalZoneResponse": {
        "type": "object",
        "description": "공통 응답 구조체",
        "properties": {
          "status": {
